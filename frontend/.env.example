# Rellena con los valores de tu proyecto: Supabase Dashboard -> Project Settings -> API Keys
# Usa la PUBLISHABLE key (sb_publishable_...). Es segura en el navegador gracias a RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Solo producción: ruta base donde se sirve la app (con barras inicial y final).
# En local se deja sin definir (se usa "/"). En Vercel: VITE_BASE_PATH=/warren/
# VITE_BASE_PATH=/warren/
